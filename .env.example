# Copy this to `.env.local` and fill in real values for local dev.
# Vercel pulls these from the project's Environment Variables settings.

# RentCast — property data API. Sign up at https://www.rentcast.io/api
RENTCAST_API_KEY=

# Supabase — public (browser-safe). From Project Settings > Data API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only. Bypasses RLS, never expose to client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct connection — only used by scripts/run-migrations.mjs.
# Not needed at runtime. Pull from Project Settings > Database > Connection
# string > "URI", picking the "Direct connection" not the pooler.
POSTGRES_URL_NON_POOLING=

# Google Maps Platform — geocoding + Places + Distance Matrix.
# Server-side only. Powers auto-fill of flood zone, nearby amenities,
# parks, and commute times in /api/property-lookup.
GOOGLE_MAPS_API_KEY=
